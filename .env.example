# Copy this to .env and add your OpenAI key.
OPENAI_API_KEY=your_openai_api_key_here

# Qdrant and Redis are configured in docker-compose.
QDRANT_URL=http://qdrant:6333
REDIS_HOST=redis
REDIS_PORT=6379
QDRANT_COLLECTION_NAME=langchainjs-testing

# Client API base URL for browser fetch.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
